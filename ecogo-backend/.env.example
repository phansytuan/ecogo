# App
PORT=3000
NODE_ENV=development

# Database (matches docker-compose)
DATABASE_URL=postgres://ecogo:ecogo@localhost:5432/ecogo

# Redis (used from Step 2 onward)
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=30d

# OTP: in dev the code is returned in the API response. Set to 'fake' for dev.
OTP_PROVIDER=fake

# Directions provider: 'fake' (straight line, no network) or 'goong'
DIRECTIONS_PROVIDER=fake
GOONG_API_KEY=
