PORT=3000
DATABASE_URL=postgres://ecogo:ecogo@localhost:5432/ecogo
REDIS_URL=redis://localhost:6379

# Comma-separated allowed origins for HTTP CORS and the socket gateway
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Auth
JWT_SECRET=change-me-in-production
JWT_ACCESS_EXPIRES_IN=2h
JWT_REFRESH_DAYS=30

# Providers: fake (offline dev) | goong / real
OTP_PROVIDER=fake
# eSMS.vn credentials (required when OTP_PROVIDER=esms; ESMS_SANDBOX=true for test sends)
ESMS_API_KEY=
ESMS_SECRET_KEY=
ESMS_BRANDNAME=
ESMS_SMS_TYPE=2
ESMS_SANDBOX=false
DIRECTIONS_PROVIDER=fake
GOONG_API_KEY=

# Address search / geocoding (defaults to DIRECTIONS_PROVIDER when unset)
PLACES_PROVIDER=fake
PLACES_CACHE_TTL_S=86400

# Detour matching: a ride is eligible while
#   matched route distance <= original remaining distance * (1 + ratio)
MATCHING_MAX_DETOUR_RATIO=0.20
# Routing-provider budget per search (rides evaluated / insertion plans routed
# per ride) and per-call timeout.
MATCHING_MAX_ROUTED_CANDIDATES=8
MATCHING_MAX_ROUTED_COMBOS=6
MATCHING_ROUTING_TIMEOUT_MS=8000

# Directions cache (route geometry is static; the biggest map-API cost lever)
DIRECTIONS_CACHE_PRECISION=4
DIRECTIONS_CACHE_TTL_S=2592000

# Cleanup job grace periods
MAINTENANCE_RIDE_GRACE_HOURS=2
MAINTENANCE_REQUEST_GRACE_MIN=30

# Push (set NOTIFICATION_PROVIDER=fcm to enable; else logs only)
NOTIFICATION_PROVIDER=fake
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

# Ride posting window: how late a driver may log a departure, and how far ahead
# a ride may be scheduled.
RIDES_MAX_BACKDATE_MIN=60
RIDES_MAX_AHEAD_DAYS=30
# Provider road distance required to publish, and endpoint equality tolerance.
RIDES_MINIMUM_DISTANCE_M=35000
RIDES_SAME_LOCATION_TOLERANCE_M=50
# Require admin-verified KYC before a driver may post rides (enable in production).
REQUIRE_DRIVER_KYC=false
# Days after signup during which a driver may claim having referred a user.
REFERRAL_CLAIM_WINDOW_DAYS=14
# Error tracking (leave empty to disable)
SENTRY_DSN=

# Required in production:
# JWT_SECRET must contain at least 32 characters.
# OTP_PROVIDER must be set to a provider other than fake.
# DATABASE_URL must be set.
# REDIS_URL must be set.
