    "@nestjs/throttler": "^6.2.1",
    "@nestjs/websockets": "^11.1.28",
    "axios": "^1.7.7",
    "bullmq": "^5.21.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "google-auth-library": "^10.9.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
